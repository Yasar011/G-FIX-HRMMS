{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        "role": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val().matches(/^(hr_admin|superadmin|admin)$/) || ($uid === auth.uid && !data.exists() && ((!root.child('users').exists() && newData.val() === 'hr_admin') || newData.val() === 'management')))"
        },
        "department": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val().matches(/^(hr_admin|superadmin|admin)$/) || ($uid === auth.uid && !data.exists()))"
        },
        "$other": {
          ".write": "auth != null && ($uid === auth.uid || root.child('users').child(auth.uid).child('role').val().matches(/^(hr_admin|superadmin|admin)$/))"
        }
      }
    },

    "employees": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val().matches(/^(hr_admin|superadmin|admin|hr_executive|editor)$/)"
    },

    "attendance": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val().matches(/^(hr_admin|superadmin|admin|hr_executive|editor|dept_manager|manager)$/)"
    },

