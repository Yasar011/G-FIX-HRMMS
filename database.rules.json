{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'superadmin')"
      }
    },

    "content": {
      ".read": true,
      ".write": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'editor')",
      "projects": {
        ".indexOn": ["slug", "priority"]
      }
    },

    "messages": {
      ".read": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'editor')",
      ".write": "auth !== null && (root.child('users').child(auth.uid).child('role').val() === 'superadmin' || root.child('users').child(auth.uid).child('role').val() === 'editor')"
    },

    "settings": {
      ".read": true,
      ".write": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'superadmin'"
    }
  }
}
